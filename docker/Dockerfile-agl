FROM nvcr.io/nvidia/pytorch:24.12-py3

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /workspace

RUN apt-get update && apt-get install -y curl \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --upgrade pip setuptools wheel setuptools_scm

COPY agl-zzh.lock /workspace/agl.lock


RUN pip install --upgrade pip \
    && pip install -r agl.lock --no-cache-dir --no-build-isolation


RUN python -c "import agentlightning, os; print(os.path.dirname(agentlightning.__file__))"

RUN AGENT_PATH=$(python -c "import agentlightning, os; print(os.path.dirname(agentlightning.__file__))") \
    && cd $AGENT_PATH/dashboard \
    && npm ci \
    && npm run build

# 验证版本
RUN python -c "import torch; print('torch:', torch.__version__)"
RUN python -c "import agentlightning; print('agentlightning OK')"

CMD ["bash"]
